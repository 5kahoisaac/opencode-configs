{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "default_builder_enabled": true
  },
  "disabled_mcps": [
    "context7",
    "websearch",
    "ast_grep",
    "grep_app"
  ],
  "agents": {
    "sisyphus": {
      "model": "zai-coding-plan/glm-5.2",
      "variant": "max",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
        "zai-coding-plan/glm-5.1",
        "opencode/big-pickle"
      ],
      "prompt_append": "Delegate heavily to hephaestus for implementation. Parallelize exploration."
    },
    "metis": {
      "model": "zai-coding-plan/glm-5.2",
      "variant": "max",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "high"
        }
      ]
    },
    "prometheus": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "zai-coding-plan/glm-5.2",
          "variant": "max"
        },
        {
          "model": "github-copilot/gemini-3.1-pro",
          "variant": "high"
        }
      ],
      "prompt_append": "Keep plans concise. Focus on file structure and key decisions."
    },
    "atlas": {
      "model": "zai-coding-plan/glm-5.1",
      "variant": "high",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
        "nvidia/minimaxai/minimax-m2.7"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "ultrawork": {
        "model": "openai/gpt-5.5",
        "variant": "medium"
      },
      "fallback_models": [],
      "prompt_append": "You are the primary implementation agent. Own the codebase. Explore, decide, execute. Use LSP and AST-grep aggressively."
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro",
          "variant": "high"
        },
        {
          "model": "zai-coding-plan/glm-5.2",
          "variant": "max"
        },
        "zai-coding-plan/glm-5.1"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro",
          "variant": "high"
        },
        {
          "model": "zai-coding-plan/glm-5.2",
          "variant": "max"
        },
        "zai-coding-plan/glm-5.1"
      ]
    },
    "explore": {
      "model": "nvidia/minimaxai/minimax-m2.7",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "github-copilot/gemini-3-flash-preview"
      ]
    },
    "librarian": {
      "model": "nvidia/minimaxai/minimax-m2.7",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "github-copilot/gemini-3-flash-preview"
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "zai-coding-plan/glm-5v-turbo",
        "github-copilot/gpt-5-mini"
      ]
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "nvidia/minimaxai/minimax-m2.7",
        "opencode/big-pickle"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro",
      "variant": "high",
      "fallback_models": [
        {
          "model": "zai-coding-plan/glm-5.2",
          "variant": "max"
        },
        "zai-coding-plan/glm-5.1"
      ]
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.5"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro",
          "variant": "high"
        },
        {
          "model": "zai-coding-plan/glm-5.2",
          "variant": "max"
        },
        "zai-coding-plan/glm-5.1"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro",
          "variant": "high"
        }
      ]
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "nvidia/minimaxai/minimax-m2.7",
        "github-copilot/gpt-5-mini"
      ]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "zai-coding-plan/glm-5.2",
          "variant": "max"
        },
        "zai-coding-plan/glm-5.1"
      ]
    },
    "unspecified-low": {
      "model": "github-copilot/gpt-5.3-codex",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        },
        "nvidia/minimaxai/minimax-m2.7"
      ]
    },
    "writing": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        "nvidia/minimaxai/minimax-m2.7"
      ]
    },
    "git": {
      "model": "github-copilot/gpt-5-mini",
      "fallback_models": [
        "zai-coding-plan/glm-4.7",
        "zai-coding-plan/glm-4.5-air",
        "opencode/big-pickle"
      ],
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations."
    }
  },
  "claude_code": {
    "mcp": false,
    "plugins_override": {
      "ecc@ecc": false,
      "codex@openai-codex": false,
      "andrej-karpathy-skills@karpathy-skills": false
    }
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 60000,
    "providerConcurrency": {
      "omlx": 1,
      "nvidia": 3,
      "openai": 5,
      "opencode": 10,
      "github-copilot": 10,
      "zai-coding-plan": 10
    },
    "modelConcurrency": {
      "openai/gpt-5.5": 2,
      "openai/gpt-5.4": 5,
      "openai/gpt-5.4-mini": 10,
      "github-copilot/gemini-2.5-pro": 2,
      "github-copilot/gemini-3-flash-preview": 5,
      "github-copilot/gemini-3.1-pro-preview": 2,
      "zai-coding-plan/glm-4.5-air": 5,
      "zai-coding-plan/glm-4.7": 2,
      "zai-coding-plan/glm-5-turbo": 1,
      "zai-coding-plan/glm-5v-turbo": 1,
      "zai-coding-plan/glm-5.1": 10,
      "zai-coding-plan/glm-5.2": 10
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  }
}
