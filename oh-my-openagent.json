{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "default_builder_enabled": true
  },
  "agents": {
    "sisyphus": {
      "model": "digitalocean/kimi-k2.6",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
        "zai-coding-plan/glm-5.1",
        "digitalocean/glm-5",
        "opencode/big-pickle"
      ]
    },
    "metis": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5.2",
        "digitalocean/kimi-k2.5"
      ]
    },
    "prometheus": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5.2",
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },
    "atlas": {
      "model": "digitalocean/kimi-k2.6",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
        "nvidia/minimaxai/minimax-m2.7"
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "ultrawork": {
        "model": "openai/gpt-5.5",
        "variant": "medium"
      },
      "fallback_models": []
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        },
        "zai-coding-plan/glm-5.2",
        "zai-coding-plan/glm-5.1"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        },
        "zai-coding-plan/glm-5.2",
        "zai-coding-plan/glm-5.1"
      ]
    },
    "explore": {
      "model": "nvidia/minimaxai/minimax-m2.7",
      "fallback_models": [
        "digitalocean/deepseek-3.2",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.4-nano"
      ]
    },
    "librarian": {
      "model": "nvidia/minimaxai/minimax-m2.7",
      "fallback_models": [
        "digitalocean/deepseek-3.2",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.4-nano"
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "digitalocean/kimi-k2.6",
        "zai-coding-plan/glm-5v-turbo"
      ]
    },
    "sisyphus-junior": {
      "model": "digitalocean/kimi-k2.6",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
        "nvidia/minimaxai/minimax-m2.7",
        "opencode/big-pickle"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "digitalocean/glm-5",
        "zai-coding-plan/glm-5.2",
        "zai-coding-plan/glm-5.1",
        "digitalocean/kimi-k2.5"
      ]
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.5"
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        },
        "zai-coding-plan/glm-5.2",
        "zai-coding-plan/glm-5.1"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ]
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview",
        "nvidia/minimaxai/minimax-m2.7",
        "opencode/big-pickle"
      ]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        "digitalocean/glm-5",
        "digitalocean/kimi-k2.5"
      ]
    },
    "unspecified-low": {
      "model": "digitalocean/kimi-k2.6",
      "fallback_models": [
        {
          "model": "openai/gpt-5.3-codex",
          "variant": "medium"
        },
        "github-copilot/gemini-3-flash-preview",
        "nvidia/minimaxai/minimax-m2.7"
      ]
    },
    "writing": {
      "model": "digitalocean/kimi-k2.5",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview",
        "digitalocean/kimi-k2.6",
        "nvidia/minimaxai/minimax-m2.7"
      ]
    },
    "git": {
      "model": "github-copilot/gpt-5-mini",
      "fallback_models": [
        "opencode/big-pickle",
        "zai-coding-plan/glm-4.5-air"
      ],
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations."
    }
  },
  "claude_code": {
    "plugins_override": {
      "ecc@ecc": false,
      "serena@claude-plugins-official": false,
      "context7@claude-plugins-official": false,
      "figma@claude-plugins-official": false,
      "atlassian@claude-plugins-official": false,
      "codex@openai-codex": false
    }
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 60000,
    "providerConcurrency": {
      "omlx": 1,
      "xai": 5,
      "nvidia": 3,
      "openai": 5,
      "opencode": 10,
      "digitalocean": 3,
      "github-copilot": 5,
      "zai-coding-plan": 10
    },
    "modelConcurrency": {
      "openai/gpt-5.5": 1,
      "openai/gpt-5.4": 2,
      "openai/gpt-5.3-codex": 3,
      "openai/gpt-5.4-mini": 5,
      "openai/gpt-5.4-nano": 8,
      "zai-coding-plan/glm-4.5-air": 5,
      "zai-coding-plan/glm-4.7": 2,
      "zai-coding-plan/glm-5-turbo": 1,
      "zai-coding-plan/glm-5v-turbo": 1,
      "zai-coding-plan/glm-5.1": 10,
      "zai-coding-plan/glm-5.2": 5
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  }
}
