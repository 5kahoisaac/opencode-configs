{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "default_builder_enabled": true
  },
  "codegraph": {
    "enabled": false,
    "auto_init": false,
    "auto_provision": false
  },
  "disabled_mcps": [
    "context7",
    "websearch",
    "ast_grep",
    "grep_app",
    "codegraph"
  ],
  "team_mode": {
    "enabled": true,
    "tmux_visualization": true
  },
  "agents": {
    "sisyphus": {
      "model": "omni/glm/glm-5.2",
      "variant": "max",
      "ultrawork": {
        "model": "omni/codex/gpt-5.5",
        "variant": "medium"
      },
      "fallback_models": [
        "omni/glm/glm-5.1",
        "omni/opencode-zen/big-pickle"
      ],
      "prompt_append": "Delegate heavily to hephaestus for implementation. Parallelize exploration."
    },
    "metis": {
      "model": "omni/glm/glm-5.2",
      "variant": "max",
      "fallback_models": [
        {
          "model": "omni/codex/gpt-5.5",
          "variant": "high"
        }
      ]
    },
    "prometheus": {
      "model": "omni/codex/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "omni/glm/glm-5.2",
          "variant": "max"
        }
      ],
      "prompt_append": "Keep plans concise. Focus on file structure and key decisions."
    },
    "atlas": {
      "model": "omni/codex/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "omni/nvidia/minimaxai/minimax-m3",
        "omni/nvidia/minimaxai/minimax-m2.7"
      ]
    },
    "hephaestus": {
      "model": "omni/codex/gpt-5.6-sol",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "omni/codex/gpt-5.5",
          "variant": "medium"
        }
      ],
      "prompt_append": "You are the primary implementation agent. Own the codebase. Explore, decide, execute. Use LSP and AST-grep aggressively."
    },
    "oracle": {
      "model": "omni/codex/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "omni/glm/glm-5.2",
          "variant": "max"
        }
      ]
    },
    "momus": {
      "model": "omni/codex/gpt-5.6-sol",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "omni/codex/gpt-5.5",
          "variant": "xhigh"
        },
        {
          "model": "omni/glm/glm-5.2",
          "variant": "max"
        }
      ]
    },
    "explore": {
      "model": "omni/nvidia/minimaxai/minimax-m3",
      "fallback_models": [
        "omni/nvidia/minimaxai/minimax-m2.7",
        "omni/gemini/gemini-3-flash-preview",
        "omni/codex/gpt-5.4-mini"
      ]
    },
    "librarian": {
      "model": "omni/nvidia/minimaxai/minimax-m3",
      "fallback_models": [
        "omni/nvidia/minimaxai/minimax-m2.7",
        "omni/gemini/gemini-3-flash-preview",
        "omni/codex/gpt-5.4-mini"
      ]
    },
    "multimodal-looker": {
      "model": "omni/codex/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "omni/glm/glm-5-turbo",
        "omni/codex/gpt-5.4-mini"
      ]
    },
    "sisyphus-junior": {
      "model": "omni/codex/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "omni/nvidia/minimaxai/minimax-m3",
        "omni/nvidia/minimaxai/minimax-m2.7",
        "omni/opencode-zen/big-pickle"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "omni/glm/glm-5.2",
      "variant": "max",
      "fallback_models": [
        "omni/glm/glm-5.1"
      ]
    },
    "artistry": {
      "model": "omni/codex/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "omni/glm/glm-5.2",
          "variant": "max"
        }
      ]
    },
    "ultrabrain": {
      "model": "omni/codex/gpt-5.6-sol",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "omni/codex/gpt-5.5",
          "variant": "xhigh"
        },
        {
          "model": "omni/glm/glm-5.2",
          "variant": "max"
        }
      ]
    },
    "deep": {
      "model": "omni/codex/gpt-5.6-terra",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "omni/codex/gpt-5.6-sol",
          "variant": "high"
        },
        {
          "model": "omni/glm/glm-5.2",
          "variant": "max"
        }
      ]
    },
    "quick": {
      "model": "omni/codex/gpt-5.4-mini",
      "fallback_models": [
        "omni/gemini/gemini-3-flash-preview",
        "omni/nvidia/minimaxai/minimax-m3",
        "omni/nvidia/minimaxai/minimax-m2.7"
      ]
    },
    "unspecified-high": {
      "model": "omni/codex/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        "omni/glm/glm-5.1",
        {
          "model": "omni/glm/glm-5.2",
          "variant": "max"
        }
      ]
    },
    "unspecified-low": {
      "model": "omni/codex/gpt-5.6-luna",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "omni/codex/gpt-5.5",
          "variant": "medium"
        },
        "omni/gemini/gemini-3-flash-preview",
        "omni/nvidia/minimaxai/minimax-m3",
        "omni/nvidia/minimaxai/minimax-m2.7"
      ]
    },
    "writing": {
      "model": "omni/gemini/gemini-3-flash-preview",
      "fallback_models": [
        "omni/nvidia/minimaxai/minimax-m3",
        "omni/nvidia/minimaxai/minimax-m2.7",
        "omni/auto/best-free"
      ]
    },
    "git": {
      "model": "omni/auto/best-free",
      "fallback_models": [
        "omni/glm/glm-4.7",
        "omni/glm/glm-4.5-air",
        "omni/opencode-zen/big-pickle"
      ],
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations."
    }
  },
  "claude_code": {
    "mcp": false,
    "plugins_override": {
      "ecc@ecc": false,
      "codex@openai-codex": false,
      "andrej-karpathy-skills@karpathy-skills": false,
      "claude-code-setup@claude-plugins-official": false,
      "understand-anything@understand-anything": false
    }
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 60000,
    "providerConcurrency": {
      "omlx": 1,
      "omni": 20
    },
    "modelConcurrency": {
      "omni/codex/gpt-5.6-sol": 1,
      "omni/codex/gpt-5.6-terra": 2,
      "omni/codex/gpt-5.6-luna": 4,
      "omni/codex/gpt-5.5": 2,
      "omni/codex/gpt-5.4": 4,
      "omni/codex/gpt-5.4-mini": 6,
      "omni/glm/glm-4.5": 10,
      "omni/glm/glm-4.5-air": 5,
      "omni/glm/glm-4.6": 3,
      "omni/glm/glm-4.7": 2,
      "omni/glm/glm-5": 2,
      "omni/glm/glm-5-turbo": 1,
      "omni/glm/glm-5.1": 10,
      "omni/glm/glm-5.2": 10
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      401,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  }
}
