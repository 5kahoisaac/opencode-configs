{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "kimi-for-coding/k2p6",
      "ultrawork": {
        "model": "github-copilot/claude-opus-4.7",
        "variant": "max"
      },
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "medium"
        },
        "zai-coding-plan/glm-5.1",
        "opencode/big-pickle"
      ]
    },
    "metis": {
      "model": "zai-coding-plan/glm-5-turbo",
      "ultrawork": {
        "model": "github-copilot/claude-opus-4.6",
        "variant": "max"
      },
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        },
        "kimi-for-coding/k2p6"
      ]
    },
    "prometheus": {
      "model": "zai-coding-plan/glm-5.1",
      "ultrawork": {
        "model": "github-copilot/claude-opus-4.6",
        "variant": "max"
      },
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        },
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        "kimi-for-coding/k2p6",
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium",
      "fallback_models": []
    },
    "oracle": {
      "model": "zai-coding-plan/glm-5",
      "ultrawork": {
        "model": "github-copilot/gpt-5.4",
        "variant": "high"
      },
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        },
        {
          "model": "github-copilot/claude-opus-4.6",
          "variant": "max"
        }
      ]
    },
    "momus": {
      "model": "zai-coding-plan/glm-5",
      "ultrawork": {
        "model": "github-copilot/gpt-5.4",
        "variant": "xhigh"
      },
      "fallback_models": [
        {
          "model": "github-copilot/claude-opus-4.6",
          "variant": "max"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ]
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1",
      "fallback_models": [
        "github-copilot/claude-haiku-4.5",
        "opencode/gpt-5-nano"
      ]
    },
    "librarian": {
      "model": "opencode/gemini-3-flash",
      "fallback_models": [
        "github-copilot/claude-haiku-4.5",
        "opencode/gpt-5-nano"
      ]
    },
    "multimodal-looker": {
      "model": "kimi-for-coding/k2p6",
      "ultrawork": {
        "model": "github-copilot/gpt-5.4",
        "variant": "medium"
      },
      "fallback_models": [
        "zai-coding-plan/glm-4.6v",
        "opencode/gpt-5-nano"
      ]
    },
    "sisyphus-junior": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        "kimi-for-coding/k2p6",
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "medium"
        },
        "opencode/big-pickle"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "zai-coding-plan/glm-5.1",
        {
          "model": "github-copilot/claude-opus-4.6",
          "variant": "max"
        },
        "kimi-for-coding/k2p6"
      ]
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        },
        {
          "model": "github-copilot/claude-opus-4.6",
          "variant": "max"
        },
        "zai-coding-plan/glm-5.1"
      ]
    },
    "deep": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "github-copilot/claude-opus-4.6",
          "variant": "max"
        },
        {
          "model": "github-copilot/gemini-3.1-pro-preview",
          "variant": "high"
        }
      ]
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        {
          "model": "github-copilot/claude-opus-4.6",
          "variant": "max"
        },
        "github-copilot/gpt-5.4"
      ]
    },
    "quick": {
      "model": "github-copilot/gpt-5.4-mini",
      "fallback_models": [
        "github-copilot/claude-haiku-4.5",
        "opencode/gemini-3-flash",
        "github-copilot/gemini-3-flash-preview",
        "opencode/gpt-5-nano"
      ]
    },
    "unspecified-high": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "max",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.4",
          "variant": "high"
        },
        "zai-coding-plan/glm-5.1",
        "kimi-for-coding/k2p6"
      ]
    },
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        {
          "model": "github-copilot/gpt-5.3-codex",
          "variant": "medium"
        },
        "kimi-for-coding/k2p6",
        "opencode/gemini-3-flash",
        "github-copilot/gemini-3-flash-preview"
      ]
    },
    "writing": {
      "model": "opencode/gemini-3-flash",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview",
        "kimi-for-coding/k2p6",
        "github-copilot/claude-sonnet-4.6"
      ]
    },
    "git": {
      "model": "opencode/gpt-5-nano",
      "fallback_models": [
        "opencode/big-pickle",
        "zai-coding-plan/glm-4.5-air"
      ],
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations."
    }
  },
  "claude_code": {
    "plugins_override": {
      "serena@claude-plugins-official": false,
      "context7@claude-plugins-official": false,
      "figma@claude-plugins-official": false,
      "atlassian@claude-plugins-official": false
    }
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 60000,
    "providerConcurrency": {
      "xai": 5,
      "opencode": 10,
      "kimi-for-coding": 3,
      "zai-coding-plan": 10,
      "github-copilot": 3
    },
    "modelConcurrency": {
      "opencode/gemini-3-flash": 5,
      "opencode/gpt-5-nano": 20,
      "kimi-for-coding/k2p6": 3,
      "zai-coding-plan/glm-4.5": 10,
      "zai-coding-plan/glm-4.5v": 10,
      "zai-coding-plan/glm-4.5-air": 5,
      "zai-coding-plan/glm-4.5-flash": 2,
      "zai-coding-plan/glm-4.6": 3,
      "zai-coding-plan/glm-4.6v": 10,
      "zai-coding-plan/glm-4.7": 2,
      "zai-coding-plan/glm-4.7-flash": 1,
      "zai-coding-plan/glm-4.7-flashx": 3,
      "zai-coding-plan/glm-5": 2,
      "zai-coding-plan/glm-5v-turbo": 1,
      "zai-coding-plan/glm-5-turbo": 1,
      "zai-coding-plan/glm-5.1": 1,
      "github-copilot/claude-opus-4.7": 1,
      "github-copilot/claude-opus-4.6": 2,
      "github-copilot/claude-opus-4.5": 2,
      "github-copilot/claude-sonnet-4.6": 3,
      "github-copilot/claude-sonnet-4.5": 3,
      "github-copilot/claude-haiku-4.5": 6,
      "github-copilot/gpt-5.4": 3,
      "github-copilot/gpt-5.3-codex": 3,
      "github-copilot/gpt-5.4-mini": 5,
      "github-copilot/gpt-5-mini": 10,
      "github-copilot/gpt-4o": 10,
      "github-copilot/gemini-3-flash-preview": 6,
      "github-copilot/gemini-3.1-pro-preview": 3,
      "github-copilot/grok-code-fast-1": 8
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  }
}
