{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.4",
  "small_model": "github-copilot/claude-haiku-4.5",
  "permission": {
    "skill": {
      "*": "allow"
    },
    "todoread": "allow",
    "todowrite": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "*.lock",
      "**/*.log",
      ".cache/**",
      "build/**",
      "__pycache__/**",
      ".venv/**",
      "venv/**"
    ]
  },
  "plugin": [
    "@nick-vi/opencode-type-inject@latest",
    "opencode-with-claude@latest",
    "opencode-historian@latest",
    "oh-my-openagent@latest"
  ],
  "enabled_providers": [
    "xai",
    "nvidia",
    "opencode",
    "zai-coding-plan",
    "github-copilot"
  ],
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "http://127.0.0.1:3456",
        "apiKey": "dummy"
      }
    },
    "opencode": {
      "blacklist": [
        "claude-opus-4-7",
        "claude-opus-4-6",
        "claude-opus-4-5",
        "claude-opus-4-1",
        "claude-sonnet-4-6",
        "claude-sonnet-4-5",
        "claude-sonnet-4",
        "claude-haiku-4-5",
        "claude-3-5-haiku",
        "gpt-5.4",
        "gpt-5.4-nano",
        "gpt-5.4-pro",
        "gpt-5.5",
        "gpt-5.5-pro",
        "gpt-5.4-mini",
        "gpt-5.3-codex",
        "gpt-5.3-codex-spark",
        "gpt-5.2",
        "gpt-5.2-codex",
        "gpt-5.1",
        "gpt-5.1-codex",
        "gpt-5.1-codex-max",
        "gpt-5.1-codex-mini",
        "gpt-5",
        "gpt-5-codex",
        "gemini-3.1-pro",
        "glm-5.1",
        "glm-5",
        "minimax-m2.7",
        "minimax-m2.5",
        "kimi-k2.6",
        "kimi-k2.5",
        "qwen3.6-plus",
        "qwen3.5-plus"
      ]
    },
    "xai": {
      "blacklist": [
        "grok-2",
        "grok-2-1212",
        "grok-2-latest",
        "grok-2-vision",
        "grok-2-vision-1212",
        "grok-2-vision-latest",
        "grok-3",
        "grok-3-fast",
        "grok-3-fast-latest",
        "grok-3-latest",
        "grok-3-mini",
        "grok-3-mini-fast",
        "grok-3-mini-fast-latest",
        "grok-3-mini-latest",
        "grok-vision-beta"
      ]
    }
  },
  "mcp": {
    "vision": {
      "command": [
        "npx",
        "-y",
        "@z_ai/mcp-server"
      ],
      "enabled": true,
      "environment": {
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}",
        "Z_AI_MODE": "ZAI"
      },
      "type": "local"
    },
    "github": {
      "enabled": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT_TOKEN}"
      },
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp"
    },
    "atlassian": {
      "command": [
        "uvx",
        "mcp-atlassian"
      ],
      "enabled": false,
      "environment": {
        "CONFLUENCE_API_TOKEN": "{env:CONFLUENCE_API_TOKEN}",
        "CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
        "CONFLUENCE_USERNAME": "{env:JIRA_USERNAME}",
        "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}",
        "JIRA_URL": "{env:JIRA_URL}",
        "JIRA_USERNAME": "{env:JIRA_USERNAME}"
      },
      "type": "local"
    },
    "figma": {
      "enabled": false,
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp"
    }
  }
}
